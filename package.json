{
  "name": "jira-ticket-generator",
  "private": true,
  "version": "0.2.0",
  "versionName": "Phase 2 Step 3 — Jira Creation",
  "type": "module",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-local-lan.ps1",
    "dev:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-lan.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-dev-ports.ps1",
    "dev:restart": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-dev.ps1",
    "dev:restart:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-dev.ps1 -Lan",
    "dev:share": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-dev.ps1 -Lan",
    "lan:firewall": "powershell -ExecutionPolicy Bypass -File ./scripts/allow-lan-dev.ps1",
    "lan:diagnose": "powershell -ExecutionPolicy Bypass -File ./scripts/lan-diagnose.ps1",
    "dev:corp": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-corp.ps1",
    "dev:lan:http": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-lan-http.ps1",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "tsc -p tsconfig.extension.json && vite build --config vite.extension.config.ts",
    "dev:extension": "vite build --config vite.extension.config.ts --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "llama:server": "powershell -ExecutionPolicy Bypass -File ./scripts/start-llama.ps1",
    "preview": "vite preview",
    "api:dev": "npm run dev --prefix server",
    "api:install": "npm install --prefix server",
    "api:test": "npm test --prefix server",
    "mcp:install": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-jira-mcp.ps1"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
