# API server
PORT=3001
# Comma-separated browser origins (include LAN HTTPS URL when using npm run dev:lan)
CORS_ORIGIN=http://localhost:5173,http://192.168.0.73:5173,https://192.168.0.73:5175

# Jira Cloud site (used to build browse URLs)
JIRA_DOMAIN=company.atlassian.net

# Default Jira project when the client omits projectKey
JIRA_DEFAULT_PROJECT_KEY=QA
JIRA_DEFAULT_ISSUE_TYPE=Bug

# --- Jira MCP Server (stdio transport) ---
# Install: pip install mcp-atlassian  (or use uvx mcp-atlassian)
# Command that starts your external Jira MCP server process.
MCP_SERVER_COMMAND=mcp-atlassian
MCP_SERVER_ARGS=

# Tool name exposed by your MCP server for issue creation
MCP_JIRA_CREATE_TOOL=jira_create_issue

# Credentials are passed to the MCP child process (never sent to the browser).
JIRA_URL=https://company.atlassian.net
JIRA_USERNAME=you@company.com
JIRA_API_TOKEN=

# Set to true to return a fake issue without calling MCP (local UI testing)
JIRA_MCP_MOCK=false
