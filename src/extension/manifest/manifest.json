{
  "manifest_version": 3,
  "name": "QA Bug Assistant",
  "version": "0.2.0",
  "version_name": "Phase 2 Step 3 — Jira Creation",
  "description": "Capture bugs and generate Jira-ready tickets in seconds.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3001/*", "http://127.0.0.1:3001/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "QA Bug Assistant"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "open-assistant": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Open QA Bug Assistant"
    }
  }
}
