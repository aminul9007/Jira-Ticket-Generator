{
  "manifest_version": 3,
  "name": "QA Bug Assistant",
  "version": "1.2.2",
  "version_name": "V1 Release",
  "description": "Capture bugs and generate Jira-ready tickets in seconds.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:3001/*", "http://127.0.0.1:3001/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "512": "icons/icon-512.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "QA Bug Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "commands": {
    "open-assistant": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Open QA Bug Assistant"
    }
  }
}
