VITE_LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
VITE_LLAMACPP_API_KEY=no-key
VITE_LLAMACPP_MODEL=qwen2.5-3b-instruct
# VITE_LLAMACPP_ENABLED=true

# --- OpenAI (cloud, optional) ---
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
