# AI provider: auto (llama.cpp first, then OpenAI) | llama-cpp | openai
VITE_AI_PROVIDER=llama-cpp

# --- llama.cpp (local, OpenAI-compatible API) ---
# 1. Download: https://llama-cpp.com/download/
# 2. Start server: npm run llama
